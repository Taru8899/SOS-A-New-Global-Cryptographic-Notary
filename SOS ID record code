// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

interface ISOS {
    function firstMintBlock(address user) external view returns (uint256);
}

contract ImmutableEntityRegistry {

    struct Entity {
        address creator;
        uint256 createdAt;
        uint256 memberCount;
    }

    struct HistoricalRecord {
        uint256 entityId;
        address wallet;
        uint256 attachedAt;
        uint256 firstMintBlock;
    }

    uint256 public entityCounter;

    address public immutable sosContract;

    mapping(uint256 => Entity) public entities;

    // wallet => entity
    mapping(address => uint256) public walletToEntity;

    // entity => wallets
    mapping(uint256 => address[]) public entityMembers;

    // immutable append-only history
    HistoricalRecord[] public history;

    event EntityCreated(
        uint256 indexed entityId,
        address indexed creator
    );

    event AddressAttached(
        uint256 indexed entityId,
        address indexed wallet,
        uint256 firstMintBlock
    );

    constructor(address _sosContract) {
        sosContract = _sosContract;
    }

    /// CREATE NEW ENTITY
    function createEntity() external returns (uint256) {
        require(walletToEntity[msg.sender] == 0, "Already attached");

        uint256 mintBlock = ISOS(sosContract)
            .firstMintBlock(msg.sender);

        require(mintBlock > 0, "No SOS mint history");

        entityCounter++;

        entities[entityCounter] = Entity({
            creator: msg.sender,
            createdAt: block.timestamp,
            memberCount: 1
        });

        walletToEntity[msg.sender] = entityCounter;

        entityMembers[entityCounter].push(msg.sender);

        history.push(HistoricalRecord({
            entityId: entityCounter,
            wallet: msg.sender,
            attachedAt: block.timestamp,
            firstMintBlock: mintBlock
        }));

        emit EntityCreated(entityCounter, msg.sender);

        emit AddressAttached(
            entityCounter,
            msg.sender,
            mintBlock
        );

        return entityCounter;
    }

    /// ATTACH NEW ADDRESS TO ENTITY
    function attachToEntity(uint256 entityId) external {

        require(
            entities[entityId].creator != address(0),
            "Entity does not exist"
        );

        require(
            walletToEntity[msg.sender] == 0,
            "Already attached"
        );

        uint256 mintBlock = ISOS(sosContract)
            .firstMintBlock(msg.sender);

        require(mintBlock > 0, "No SOS mint history");

        walletToEntity[msg.sender] = entityId;

        entities[entityId].memberCount++;

        entityMembers[entityId].push(msg.sender);

        history.push(HistoricalRecord({
            entityId: entityId,
            wallet: msg.sender,
            attachedAt: block.timestamp,
            firstMintBlock: mintBlock
        }));

        emit AddressAttached(
            entityId,
            msg.sender,
            mintBlock
        );
    }

    function getEntityMembers(
        uint256 entityId
    )
        external
        view
        returns (address[] memory)
    {
        return entityMembers[entityId];
    }

    function historyLength()
        external
        view
        returns (uint256)
    {
        return history.length;
    }
}
