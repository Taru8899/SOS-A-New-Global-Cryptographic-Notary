// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

contract SOS69069 {

    // -------------------------
    // BASIC TOKEN STATE
    // -------------------------
    string public name = "SOS 69069";
    string public symbol = "SOS";
    uint8 public decimals = 0;

    uint256 public totalSupply;

    // NO TRANSFERS
    mapping(address => uint256) public balanceOf;

    // -------------------------
    // SEED (IDENTITY ROOT)
    // -------------------------
    mapping(address => bytes32) public seedOf;

    // Seed analytics
    mapping(bytes32 => uint256) public seedMintIn;
    mapping(bytes32 => uint256) public seedMintOut;
    mapping(bytes32 => mapping(bytes32 => uint256)) public seedFlow;

    // -------------------------
    // PRIME (CLUSTERS)
    // -------------------------
    struct Prime {
        address creator;
        bytes32[] seeds;
        mapping(bytes32 => bool) isMember;
    }

    mapping(uint256 => Prime) public primes;
    uint256 public primeCount;

    // -------------------------
    // WAVE (GOVERNANCE)
    // -------------------------
    struct Wave {
        address creator;
        uint256 weight;
        mapping(bytes32 => bool) voted;
    }

    mapping(uint256 => Wave) public waves;
    uint256 public waveCount;

    // -------------------------
    // REPUTATION
    // -------------------------
    mapping(bytes32 => uint256) public reputation;

    // -------------------------
    // MINT LIMIT SYSTEM (NEW)
    // -------------------------
    uint256 public constant DAILY_LIMIT = 86400;

    mapping(address => uint256) public lastMintDay;
    mapping(address => uint256) public mintedToday;

    // -------------------------
    // EVENTS (GRAPH INDEXER)
    // -------------------------
    event SeedDeclared(address indexed user, bytes32 seed);

    event Mint(
        address indexed from,
        address indexed to,
        bytes32 fromSeed,
        bytes32 toSeed
    );

    event PrimeCreated(uint256 indexed primeId, address creator);
    event PrimeJoined(uint256 indexed primeId, bytes32 seed);

    event WaveCreated(uint256 indexed waveId, address creator);
    event WaveJoined(uint256 indexed waveId, bytes32 seed, uint256 weight);

    // -------------------------
    // SEED DECLARATION
    // -------------------------
    function declareSeed(address origin) external {
        bytes32 id = keccak256(abi.encodePacked(origin));
        seedOf[msg.sender] = id;

        emit SeedDeclared(msg.sender, id);
    }

    // -------------------------
    // ATOMIC MINT (STRICT LIMIT)
    // -------------------------
    function mint(address to) external {
        require(to != address(0), "Invalid address");

        uint256 day = block.timestamp / 1 days;

        // reset daily counter
        if (lastMintDay[msg.sender] != day) {
            mintedToday[msg.sender] = 0;
            lastMintDay[msg.sender] = day;
        }

        require(
            mintedToday[msg.sender] < DAILY_LIMIT,
            "Daily atomic mint limit reached"
        );

        mintedToday[msg.sender] += 1;

        bytes32 fromSeed = seedOf[msg.sender];
        bytes32 toSeed = seedOf[to];

        // token assignment (NO TRANSFER MODEL)
        balanceOf[msg.sender] += 1;
        totalSupply += 1;

        // Seed tracking
        if (fromSeed != bytes32(0)) {
            seedMintOut[fromSeed] += 1;
        }

        if (toSeed != bytes32(0)) {
            seedMintIn[toSeed] += 1;
        }

        // cross-seed flow
        if (fromSeed != bytes32(0) && toSeed != bytes32(0)) {
            seedFlow[fromSeed][toSeed] += 1;
        }

        emit Mint(msg.sender, to, fromSeed, toSeed);
    }

    // -------------------------
    // PRIME SYSTEM
    // -------------------------
    function createPrime() external returns (uint256) {
        uint256 id = primeCount++;
        primes[id].creator = msg.sender;

        emit PrimeCreated(id, msg.sender);
        return id;
    }

    function joinPrime(uint256 primeId) external {
        bytes32 seed = seedOf[msg.sender];
        require(seed != bytes32(0), "No Seed");

        Prime storage p = primes[primeId];

        if (!p.isMember[seed]) {
            p.isMember[seed] = true;
            p.seeds.push(seed);

            emit PrimeJoined(primeId, seed);
        }
    }

    // -------------------------
    // WAVE SYSTEM
    // -------------------------
    function createWave() external returns (uint256) {
        uint256 id = waveCount++;
        waves[id].creator = msg.sender;

        emit WaveCreated(id, msg.sender);
        return id;
    }

    function joinWave(uint256 waveId) external {
        bytes32 seed = seedOf[msg.sender];
        require(seed != bytes32(0), "No Seed");

        Wave storage w = waves[waveId];

        if (!w.voted[seed]) {
            w.voted[seed] = true;

            uint256 weightValue = reputation[seed] + 1;
            w.weight += weightValue;

            reputation[seed] += 1;

            emit WaveJoined(waveId, seed, weightValue);
        }
    }

    // -------------------------
    // REPUTATION VIEW
    // -------------------------
    function getReputation(bytes32 seed) external view returns (uint256) {
        return reputation[seed];
    }

    // -------------------------
    // NO ETH POLICY
    // -------------------------
    receive() external payable {
        revert("No ETH allowed");
    }

    fallback() external payable {
        revert("No ETH allowed");
    }
}


