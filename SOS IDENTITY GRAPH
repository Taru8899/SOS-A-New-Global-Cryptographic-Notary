🔵 Module C — OPEN JOIN SYSTEM

ANY address can join ANY identity or cluster

function joinCluster(bytes32 id) external {
    clusterOf[msg.sender] = id;
    clusterMembers[id].push(msg.sender);
}

function joinPerson(bytes32 id) external {
    personOf[msg.sender] = id;
    personAddresses[id].push(msg.sender);
}

