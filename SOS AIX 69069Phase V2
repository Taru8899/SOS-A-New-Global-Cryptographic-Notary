// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

/**
 * @title NON-STANDARD ETH SOS AIX by 69069
 * @notice Pure forward mint contract with strict safety constraints.
 * 
 * SAFETY BLOCK:
 * - Exactly 1 wei (0.000000000000000001) token minted per call
 * - Push is the only mint function
 * - No self mint / No mint to zero address / No mint to contract
 * - No ETH accepted or held
 * - No transfers, approvals, burns, DEX logic, proxies, or ownable
 * - No selfdestruct
 * - Reentrancy protected
 */

contract Sosaix69069 {
    string public constant name = "SOS AIX";
    string public constant symbol = "SOS AIX";
    uint8 public constant decimals = 18;

    // ==================== INTERNAL STATE ====================
    uint256 private _69069Phase;
    mapping(address => uint256) private Trustof;

    mapping(address => bool) private _hasReceived;  // Tracks addresses that received at least one Push
    mapping(address => bool) private _hasPushed;    // Tracks addresses that have called Push at least once

    bool private _pushing; // Reentrancy guard

    // ==================== CONSTANTS ====================
    uint256 private constant EXACT_MINT_AMOUNT = 1; // 1 wei token

    // ==================== EVENTS ====================
    /** @notice Emitted every time a Push mint occurs */
    event Push(address indexed to, uint256 amount);
    
    /** @notice Emitted only once per address — when they call Push for the first time */
    event Push1(address indexed from);

    // ==================== ERRORS ====================
    error ReentrantPush();
    error NoETHAccepted();
    error PushToZeroAddress();
    error NoSelfMint();
    error NoSelfPush();

    // ==================== VIEW FUNCTIONS ====================
    function totalSupply() public view returns (uint256) {
        return _69069Phase;
    }

    function balanceOf(address account) public view returns (uint256) {
        return Trustof[account];
    }

    /**
     * @notice Returns whether an address has ever received a Push (mint)
     */
    function hasReceived(address account) public view returns (bool) {
        return _hasReceived[account];
    }

    /**
     * @notice Returns whether an address has ever called Push (first Push indicator)
     */
    function hasPushed(address account) public view returns (bool) {
        return _hasPushed[account];
    }

    // ==================== PUSH - ONLY MINT FUNCTION ====================
    /**
     * @notice Mint exactly 1 wei token to any address (except self, zero, or contract)
     * @dev Emits Push on every call, and Push1 only on the caller's first Push
     */
    function Push(address to) external {
        if (_pushing) revert ReentrantPush();
        _pushing = true;

        // === SAFETY CHECKS ===
        if (msg.value != 0) revert NoETHAccepted();
        if (to == address(0)) revert PushToZeroAddress();
        if (to == msg.sender) revert NoSelfMint();
        if (to == address(this)) revert NoSelfPush();

        address caller = msg.sender;
        uint256 amount = EXACT_MINT_AMOUNT;

        // Pure mint logic
        Trustof[to] += amount;
        _69069Phase += amount;

        // Track first receipt
        if (!_hasReceived[to]) {
            _hasReceived[to] = true;
        }

        // One-time Push1 event for caller
        if (!_hasPushed[caller]) {
            _hasPushed[caller] = true;
            emit Push1(caller);
        }

        emit Push(to, amount);

        _pushing = false;
    }

    // ==================== REJECT ETH ====================
    receive() external payable { revert NoETHAccepted(); }
    fallback() external payable { revert NoETHAccepted(); }
}
